{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "baseUrl": ".",
    "resolveJsonModule": true
  },
  "include": ["worker.ts", "lib/**/*"],
  "exclude": ["node_modules"]
}
