# Worker environment variables
# Copy to .env.worker in project root (or use worker/ directory for standalone)

# Database (PostgreSQL - same as main app)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Redis (required for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Google GMB OAuth (for token refresh when publishing)
GOOGLE_CLIENT_ID_GMB=your-gmb-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET_GMB=your-gmb-client-secret
NEXTAUTH_URL=https://your-domain.com

# Optional: Worker port for health check (default 3001)
# PORT=3001
