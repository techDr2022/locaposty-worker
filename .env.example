# Worker environment variables
# Copy to .env.worker in project root (or use worker/ directory for standalone)#5

# Database (PostgreSQL - same as main app)
DATABASE_URL=
# Redis (required for BullMQ)
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# Google GMB OAuth (for token refresh when publishing)
GOOGLE_CLIENT_ID_GMB=
GOOGLE_CLIENT_SECRET_GMB=
NEXTAUTH_URL=

# Optional: Worker port for health check (default 3001)
# PORT=3001

# Reports worker health port
REPORTS_WORKER_PORT=3002

# Resend email delivery


# S3 report storage
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# Chromium pack URL for production PDF rendering
CHROMIUM_PACK_URL=
